  <property name="styleSheet">
   <string notr="true">/*
Overall Style
*/
QWidget#centralwidget {
    background-color: #F8F9FA;
}

/*
Labels
*/


QLabel#uploadTextLabel_1 {
    color: #495057;
    font-size: 17px;
    font-weight: 500;

}


QLabel#uploadTextLabel_3 {
    color: #6C757D;
    font-size: 14px;

}
QLabel#uploadTextLabel_2 {
    color: #6C757D;
    font-size: 14px;

}


/*
Buttons
*/
QPushButton#generateButton {
    border-radius: 10px;
    border: 1px solid #E9ECEF;
    background-color: #666666;
    color: #eeeeee;
    text-align: center;
    font-weight: 600;
    font-size: 16px;
    padding: 16px;
}

QPushButton#generateButton:hover {
    background-color: #999999;
}

QPushButton#resetButton {
    background-color: transparent;
    border: none;
    color: #495057;
    font-size: 13px;
    text-align: right;
}

QPushButton#resetButton:hover {
    text-decoration: underline;
}

/*
Tab Widget
*/
QTabWidget::pane {
    border: none;
}

QTabBar::tab {
    width: 90px;
    height: 35px;
    font-size: 16px;
    font-weight: 500;
    color: #6C757D;
    border-bottom: 2px solid transparent;

    margin: 10px 10px 10px 10px;
}

QTabBar::tab:selected {
    color: #212529;
    border-bottom: 2px solid #212529;
}

QTabBar::tab:hover {
    color: #212529;
}

/*
Sliders
*/
QSlider {
    padding: 5px 0;
}

QSlider::groove:horizontal {
    border: 1px solid #DEE2E6;
    background: #e1e3e5;
    height: 6px;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #F1F1F1;
    border: 1px solid #CED4DA;
    width: 20px;
    height: 20px;
    margin: -8px 0;
    border-radius: 10px;
}

QSlider::handle:horizontal:hover {
    border-color: #ADB5BD;
}

/*
Switches (Styled QCheckBox)
*/

CheckBox {
    font-size: 14px;
    color: #343A40;
    font-weight: 500;
}
/*
Frames and Separators
*/
QFrame#uploadFrame {
    background-color: #FFFFFF;
    border: 2px dashed #CED4DA;
    border-radius: 12px;
}

QFrame#uploadFrame:hover {
    background-color: #FFFFFF;
    border: 2px dashed #a1bbd7;
    border-radius: 12px;
}

QFrame#rightPanelFrame {
    background-color: #FFFFFF;
    border: 1px solid #E9ECEF;
    border-radius: 12px;
    padding: 10px;
}

QFrame#separatorLine {
    background-color: #E9ECEF;
}</string>
